{
  "name": "storyforge",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter web --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "dev:landing": "pnpm --filter landing dev",
    "storybook": "pnpm --filter web storybook",
    "test": "pnpm --filter server test && pnpm --filter web test",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": "pnpm --filter web lint:fix",
    "apps/server/**/*.ts": "pnpm --filter server lint:fix"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  }
}
