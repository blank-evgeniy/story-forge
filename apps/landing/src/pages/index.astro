---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { DoorOpen, PenLine, BookOpen, EyeOff, Timer, QrCode, Zap, GitBranch, Dices, Radio } from 'lucide-astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? '#';

const steps = [
  {
    step: '01',
    Icon: DoorOpen,
    title: 'Создайте комнату',
    desc: 'Хост задаёт настройки, получает 4-значный код и QR — и делится ими с друзьями одним нажатием.',
  },
  {
    step: '02',
    Icon: PenLine,
    title: 'Пишите по очереди',
    desc: 'Каждый добавляет одно предложение за 30–90 секунд. В Blind Mode видно только предыдущую фразу — и больше ничего.',
  },
  {
    step: '03',
    Icon: BookOpen,
    title: 'Читайте вместе',
    desc: 'После всех раундов история раскрывается фраза за фразой. Гарантировано: никто не ожидал такого финала.',
  },
];

const features = [
  { Icon: EyeOff,    title: 'Blind Mode',         desc: 'Каждый видит только последнее предложение. Хаос управляем, результат непредсказуем.' },
  { Icon: Timer,     title: 'Таймер раунда',       desc: '30, 60 или 90 секунд на ход. Ограничение времени рождает лучшие идеи.' },
  { Icon: QrCode,    title: 'Вход по QR-коду',     desc: 'Наведи камеру — и ты уже в игре. Никаких регистраций и паролей.' },
  { Icon: Zap,       title: 'Реальное время',       desc: 'WebSocket-соединение: всё происходит мгновенно для всех участников.' },
  { Icon: GitBranch, title: 'Несколько историй',    desc: 'Каждый игрок строит свою ветку. В финале историй столько же, сколько игроков.' },
  { Icon: Dices,     title: 'Для любой компании',  desc: 'Вечеринки, тимбилдинг, онлайн-посиделки. Достаточно двух человек, чтобы начать.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <BaseHead
      title="StoryForge — совместные истории"
      description="Игра, где каждый пишет одно предложение, а никто не знает, что вышло. Совместное творчество без правил."
    />
  </head>

  <body class="antialiased">
    <Nav />

    <section class="relative min-h-screen flex flex-col justify-center pt-24 pb-16 px-6 overflow-hidden">
      <div class="pointer-events-none absolute inset-0">
        <div style="position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:900px;height:700px;border-radius:50%;background:radial-gradient(ellipse,rgba(242,193,78,0.13) 0%,rgba(200,146,42,0.06) 40%,transparent 70%);filter:blur(20px);"></div>
        <div style="position:absolute;top:30%;left:-15%;width:600px;height:500px;border-radius:50%;background:radial-gradient(ellipse,rgba(139,26,46,0.25) 0%,transparent 65%);filter:blur(40px);"></div>
        <div style="position:absolute;top:20%;right:-10%;width:500px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(224,123,63,0.12) 0%,transparent 65%);filter:blur(50px);"></div>
        <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:800px;height:300px;border-radius:50%;background:radial-gradient(ellipse,rgba(139,26,46,0.15) 0%,transparent 70%);filter:blur(30px);"></div>
      </div>

      <div class="relative mx-auto max-w-5xl w-full">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <div>
            <div class="badge-gold mb-8 animate-reveal reveal-1 w-fit">
              <Radio size={13} stroke-width={1.5} class="animate-pulse-glow" />
              Мультиплеер · В реальном времени
            </div>

            <h1 class="font-display font-black leading-[1.0] tracking-tight mb-6 animate-reveal reveal-2" style="font-size:clamp(2.8rem,6vw,4.5rem);">
              <span style="color:#f5ead8;">Истории,</span><br />
              <span class="text-gold-gradient">рождённые</span><br />
              <span class="text-gold-gradient">вместе</span>
            </h1>

            <p class="font-body text-lg leading-relaxed mb-10 animate-reveal reveal-3" style="color:#c4a882;max-width:38ch;">
              Каждый пишет одно предложение — и никто не видит, что написали остальные.
              Результат невозможно придумать намеренно. И именно это так весело.
            </p>

            <div class="flex flex-col sm:flex-row gap-3 animate-reveal reveal-4">
              <a href={appUrl} target="_blank" rel="noopener noreferrer" class="btn-gold rounded-[10px] px-8 py-4 text-base font-display font-bold text-center">
                Создать комнату
              </a>
              <a href="#how" class="btn-ghost rounded-[10px] px-8 py-4 text-base text-center">
                Как это работает
              </a>
            </div>

            <p class="mt-8 font-body text-sm animate-reveal reveal-4" style="color:#7d5e48;">
              Без регистрации · Бесплатно · Прямо в браузере
            </p>
          </div>

          <div class="animate-float animate-reveal reveal-3" style="animation-delay:0.3s;">
            <div class="relative">
              <div style="position:absolute;inset:-24px;background:radial-gradient(ellipse,rgba(242,193,78,0.14) 0%,transparent 70%);border-radius:2rem;filter:blur(16px);" class="animate-breathe"></div>

              <div class="parchment rounded-[20px] overflow-hidden relative">
                <div style="padding:12px 20px;border-bottom:1px solid rgba(242,193,78,0.12);background:rgba(10,4,6,0.6);display:flex;align-items:center;gap:8px;">
                  <div style="width:10px;height:10px;border-radius:50%;background:#c0392b;opacity:0.8;"></div>
                  <div style="width:10px;height:10px;border-radius:50%;background:#f39c12;opacity:0.8;"></div>
                  <div style="width:10px;height:10px;border-radius:50%;background:#27ae60;opacity:0.8;"></div>
                  <span class="font-mono text-xs ml-3" style="color:#7d5e48;">story-room-42AX · 3 игрока</span>
                </div>

                <div style="padding:24px;display:flex;flex-direction:column;gap:18px;">
                  <div style="display:flex;gap:12px;align-items:flex-start;">
                    <div class="avatar-a shrink-0" style="width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;font-weight:700;">А</div>
                    <div style="flex:1;padding-top:4px;">
                      <p class="font-body text-sm leading-relaxed" style="color:#f5ead8;">Дракон проснулся и обнаружил, что кто-то выпил весь его чай.</p>
                    </div>
                  </div>

                  <div style="height:1px;background:linear-gradient(to right,transparent,rgba(242,193,78,0.1),transparent);"></div>

                  <div style="display:flex;gap:12px;align-items:flex-start;">
                    <div class="avatar-m shrink-0" style="width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;font-weight:700;">М</div>
                    <div style="flex:1;padding-top:4px;">
                      <p class="font-body text-sm leading-relaxed" style="color:#f5ead8;">Виновником оказался маленький гном в полосатых носках и деловом галстуке.</p>
                    </div>
                  </div>

                  <div style="height:1px;background:linear-gradient(to right,transparent,rgba(242,193,78,0.1),transparent);"></div>

                  <div style="display:flex;gap:12px;align-items:flex-start;">
                    <div class="avatar-k shrink-0" style="width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;font-weight:700;">К</div>
                    <div style="flex:1;padding-top:4px;">
                      <p class="font-body text-sm leading-relaxed" style="color:#f5ead8;">Дракон не разозлился — он просто предложил сыграть в шахматы на желание.</p>
                    </div>
                  </div>

                  <div style="height:1px;background:linear-gradient(to right,transparent,rgba(242,193,78,0.1),transparent);"></div>

                  <div style="display:flex;gap:12px;align-items:flex-start;opacity:0.45;">
                    <div style="width:30px;height:30px;border-radius:50%;background:rgba(242,193,78,0.05);border:1px solid rgba(242,193,78,0.12);display:flex;align-items:center;justify-content:center;">
                      <div style="display:flex;gap:3px;align-items:center;">
                        <span style="width:4px;height:4px;border-radius:50%;background:#7d5e48;" class="animate-pulse"></span>
                        <span style="width:4px;height:4px;border-radius:50%;background:#7d5e48;animation-delay:0.15s;" class="animate-pulse"></span>
                        <span style="width:4px;height:4px;border-radius:50%;background:#7d5e48;animation-delay:0.3s;" class="animate-pulse"></span>
                      </div>
                    </div>
                    <p class="font-body text-sm italic" style="color:#7d5e48;padding-top:6px;">Игрок думает над продолжением...</p>
                  </div>
                </div>

                <div style="height:2px;background:rgba(242,193,78,0.06);">
                  <div style="height:100%;width:75%;background:linear-gradient(to right,#8b1a2e,#c8922a,#f2c14e);border-radius:1px;"></div>
                </div>

                <div style="padding:10px 20px;display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.3);">
                  <span class="font-mono text-xs" style="color:#7d5e48;">Раунд 3 из 4</span>
                  <span class="font-mono text-xs" style="color:#c8922a;">⏱ 0:23</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
        <span class="font-body text-xs" style="color:#7d5e48;">листайте вниз</span>
        <div style="width:1px;height:32px;background:linear-gradient(to bottom,rgba(242,193,78,0.5),transparent);"></div>
      </div>
    </section>

    <section id="how" class="relative py-28 px-6 overflow-hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(139,26,46,0.2) 0%,transparent 65%);pointer-events:none;"></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="text-center mb-16">
          <div class="ornament mb-5 font-mono text-xs tracking-[0.3em] uppercase" style="color:rgba(242,193,78,0.5);">
            Механика игры
          </div>
          <h2 class="font-display font-black tracking-tight mb-4" style="color:#f5ead8;font-size:clamp(2.2rem,5vw,3.5rem);">
            Три шага до смеха
          </h2>
          <p class="font-body" style="color:#c4a882;">Простые правила — бесконечные вариации сюжета</p>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {steps.map(({ step, Icon, title, desc }) => (
            <div class="card-warm rounded-[--radius-xl] p-8 overflow-hidden relative group">
              <div class="step-number absolute top-4 right-5 select-none leading-none">{step}</div>
              <div style="display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,rgba(242,193,78,0.15),rgba(224,123,63,0.08));border:1px solid rgba(242,193,78,0.2);margin-bottom:1.25rem;">
                <Icon size={24} color="#f2c14e" stroke-width={1.5} />
              </div>
              <h3 class="font-display font-bold text-lg mb-3 group-hover:text-[#f2c14e] transition-colors duration-300" style="color:#f5ead8;">{title}</h3>
              <p class="font-body text-sm leading-relaxed" style="color:#c4a882;">{desc}</p>
              <div style="position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(242,193,78,0),transparent);transition:all 0.4s;" class="group-hover:[background:linear-gradient(to_right,transparent,rgba(242,193,78,0.4),transparent)]"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="features" class="relative py-28 px-6 overflow-hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 50% 100%,rgba(224,123,63,0.08) 0%,transparent 65%),linear-gradient(to bottom,transparent,rgba(26,12,16,0.6),transparent);pointer-events:none;"></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="text-center mb-16">
          <div class="ornament mb-5 font-mono text-xs tracking-[0.3em] uppercase" style="color:rgba(242,193,78,0.5);">
            Возможности
          </div>
          <h2 class="font-display font-black tracking-tight mb-4" style="color:#f5ead8;font-size:clamp(2.2rem,5vw,3.5rem);">
            Всё для весёлой игры
          </h2>
          <p class="font-body" style="color:#c4a882;">Продуманные инструменты, которые не мешают, а помогают</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {features.map(({ Icon, title, desc }) => (
            <div class="card-warm rounded-[--radius-lg] p-6 group cursor-default">
              <div style="display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(242,193,78,0.12),rgba(224,123,63,0.06));border:1px solid rgba(242,193,78,0.18);margin-bottom:1rem;">
                <Icon size={20} color="#f2c14e" stroke-width={1.5} />
              </div>
              <h3 class="font-display font-bold mb-2 group-hover:text-[#f2c14e] transition-colors duration-200" style="color:#f5ead8;">{title}</h3>
              <p class="font-body text-sm leading-relaxed" style="color:#c4a882;">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-28 px-6">
      <div class="mx-auto max-w-4xl">
        <div class="relative rounded-[24px] overflow-hidden text-center" style="background:linear-gradient(145deg,#1e0e16 0%,#2a1020 50%,#1c0c14 100%);border:1px solid rgba(242,193,78,0.2);box-shadow:0 0 0 1px rgba(242,193,78,0.06),0 30px 80px rgba(0,0,0,0.6),inset 0 1px 0 rgba(242,193,78,0.1);">
          <div style="position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:500px;height:300px;border-radius:50%;background:radial-gradient(ellipse,rgba(242,193,78,0.18) 0%,transparent 65%);filter:blur(20px);pointer-events:none;" class="animate-breathe"></div>
          <div style="height:2px;background:linear-gradient(to right,transparent,rgba(242,193,78,0.6),rgba(224,123,63,0.4),transparent);"></div>

          <div class="relative px-8 md:px-16 py-14">
            <div class="badge-gold mx-auto mb-6 w-fit">
              <EyeOff size={14} stroke-width={1.5} /> Главная фишка
            </div>
            <h2 class="font-display font-black tracking-tight mb-5" style="color:#f5ead8;font-size:clamp(1.9rem,4vw,3rem);">
              Blind Mode —<br />
              <span class="text-gold-gradient">хаос по правилам</span>
            </h2>
            <p class="font-body text-lg leading-relaxed mb-10 mx-auto" style="color:#c4a882;max-width:44ch;">
              Когда каждый видит только одно предложение, история уходит туда, куда никто не ожидал.
              Именно в этом непредсказуемом хаосе и живёт веселье.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              {['Видно только последнее', 'Каждый раз по-новому', 'Смех гарантирован'].map((label) => (
                <div style="display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-radius:10px;background:rgba(242,193,78,0.06);border:1px solid rgba(242,193,78,0.18);font-size:0.875rem;font-weight:500;color:#c4a882;font-family:var(--font-body);">
                  <span style="color:#f2c14e;font-size:1rem;">✦</span> {label}
                </div>
              ))}
            </div>
          </div>

          <div style="height:2px;background:linear-gradient(to right,transparent,rgba(139,26,46,0.6),rgba(224,123,63,0.3),transparent);"></div>
        </div>
      </div>
    </section>

    <section id="play" class="relative py-36 px-6 text-center overflow-hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 50% 100%,rgba(139,26,46,0.3) 0%,transparent 60%),radial-gradient(ellipse 50% 60% at 50% 80%,rgba(242,193,78,0.1) 0%,transparent 55%);pointer-events:none;"></div>

      <div class="relative mx-auto max-w-2xl">
        <div class="font-display text-5xl mb-6 animate-spin-slow" style="color:rgba(242,193,78,0.2);line-height:1;">✦</div>
        <h2 class="font-display font-black tracking-tight mb-5" style="color:#f5ead8;font-size:clamp(2.5rem,6vw,4rem);">
          Готовы к игре?
        </h2>
        <p class="font-body text-lg leading-relaxed mb-12 mx-auto" style="color:#c4a882;max-width:36ch;">
          Соберите друзей, поделитесь кодом и начните писать историю — это займёт меньше минуты.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={appUrl} target="_blank" rel="noopener noreferrer" class="btn-gold rounded-[12px] px-10 py-4 text-lg font-display font-bold text-center">
            Создать комнату →
          </a>
          <a href={`${appUrl}?tab=join`} target="_blank" rel="noopener noreferrer" class="btn-ghost rounded-[12px] px-10 py-4 text-lg text-center">
            Войти по коду
          </a>
        </div>
        <p class="mt-10 font-body text-sm" style="color:#7d5e48;">
          Без регистрации · Бесплатно · Прямо в браузере
        </p>
      </div>
    </section>

    <Footer />
  </body>
</html>
