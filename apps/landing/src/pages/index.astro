---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { DoorOpen, PenLine, BookOpen, EyeOff, Timer, QrCode, Zap, GitBranch, Dices, Radio } from 'lucide-astro';

const appUrl = import.meta.env.PUBLIC_APP_URL ?? '#';

const steps = [
  {
    step: '01',
    Icon: DoorOpen,
    title: 'Создайте комнату',
    desc: 'Хост задаёт настройки, получает 4-значный код и QR — и делится ими с друзьями одним нажатием.',
  },
  {
    step: '02',
    Icon: PenLine,
    title: 'Пишите по очереди',
    desc: 'Каждый добавляет одно предложение за 30–90 секунд. В Blind Mode видно только предыдущую фразу — и больше ничего.',
  },
  {
    step: '03',
    Icon: BookOpen,
    title: 'Читайте вместе',
    desc: 'После всех раундов история раскрывается фраза за фразой. Гарантировано: никто не ожидал такого финала.',
  },
];

const features = [
  { Icon: EyeOff,    title: 'Blind Mode',         desc: 'Каждый видит только последнее предложение. Хаос управляем, результат непредсказуем.' },
  { Icon: Timer,     title: 'Таймер раунда',       desc: '30, 60 или 90 секунд на ход. Ограничение времени рождает лучшие идеи.' },
  { Icon: QrCode,    title: 'Вход по QR-коду',     desc: 'Наведи камеру — и ты уже в игре. Никаких регистраций и паролей.' },
  { Icon: Zap,       title: 'Реальное время',       desc: 'WebSocket-соединение: всё происходит мгновенно для всех участников.' },
  { Icon: GitBranch, title: 'Несколько историй',    desc: 'Каждый игрок строит свою ветку. В финале историй столько же, сколько игроков.' },
  { Icon: Dices,     title: 'Для любой компании',  desc: 'Вечеринки, тимбилдинг, онлайн-посиделки. Достаточно двух человек, чтобы начать.' },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <BaseHead
      title="StoryForge — совместные истории"
      description="Игра, где каждый пишет одно предложение, а никто не знает, что вышло. Совместное творчество без правил."
    />
  </head>

  <body class="antialiased">
    <Nav />

    <section class="relative min-h-screen flex flex-col justify-center pt-24 pb-16 px-6 overflow-hidden">
      <div class="pointer-events-none absolute inset-0">
        <div style="position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:900px;height:700px;border-radius:50%;background:radial-gradient(ellipse,rgba(245,166,35,0.18) 0%,rgba(200,140,0,0.08) 40%,transparent 70%);filter:blur(20px);"></div>
        <div style="position:absolute;top:30%;left:-15%;width:600px;height:500px;border-radius:50%;background:radial-gradient(ellipse,rgba(245,166,35,0.12) 0%,transparent 65%);filter:blur(40px);"></div>
        <div style="position:absolute;top:20%;right:-10%;width:500px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(255,201,74,0.1) 0%,transparent 65%);filter:blur(50px);"></div>
        <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:800px;height:300px;border-radius:50%;background:radial-gradient(ellipse,rgba(255,45,120,0.08) 0%,transparent 70%);filter:blur(30px);"></div>
      </div>

      <div class="relative mx-auto max-w-5xl w-full">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <div>
            <div class="badge-game mb-8 animate-reveal reveal-1 w-fit">
              <Radio size={13} stroke-width={1.5} class="animate-pulse-orange" />
              Мультиплеер · В реальном времени
            </div>

            <h1 class="font-display font-black leading-[1.0] tracking-tight mb-6 animate-reveal reveal-2" style="font-size:clamp(2.8rem,6vw,4.5rem);">
              <span style="color:#fff8f0;">Истории,</span><br />
              <span class="text-orange-gradient">рождённые</span><br />
              <span class="text-orange-gradient">вместе</span>
            </h1>

            <p class="font-body text-lg leading-relaxed mb-10 animate-reveal reveal-3" style="color:#ffcfa0;max-width:38ch;">
              Каждый пишет одно предложение — и никто не видит, что написали остальные.
              Результат невозможно придумать намеренно. И именно это так весело.
            </p>

            <div class="flex flex-col sm:flex-row gap-3 animate-reveal reveal-4">
              <a href={appUrl} target="_blank" rel="noopener noreferrer" class="btn-primary rounded-[14px] px-8 py-4 text-base font-display font-bold text-center">
                Создать комнату
              </a>
              <a href="#how" class="btn-outline rounded-[14px] px-8 py-4 text-base text-center">
                Как это работает
              </a>
            </div>

            <p class="mt-8 font-body text-sm animate-reveal reveal-4" style="color:#b07040;">
              Без регистрации · Бесплатно · Прямо в браузере
            </p>
          </div>

          <div class="animate-reveal reveal-3" style="animation-delay:0.3s;">
            <div class="relative">
              <div style="position:absolute;inset:-24px;background:radial-gradient(ellipse,rgba(245,166,35,0.18) 0%,transparent 70%);border-radius:2rem;filter:blur(16px);"></div>

              <div class="lobby-card rounded-[20px] overflow-hidden relative">
                <!-- header -->
                <div style="padding:12px 18px;border-bottom:1px solid rgba(245,166,35,0.12);background:rgba(0,0,0,0.25);display:flex;align-items:center;justify-content:space-between;">
                  <span class="font-display font-black text-sm" style="color:#fff8f0;">📖 Story Room</span>
                  <span class="font-mono text-xs" style="color:#ffc94a;">⏱ 0:23</span>
                </div>

                <!-- messages -->
                <div style="padding:16px;display:flex;flex-direction:column;gap:10px;">

                  <div>
                    <div style="font-size:0.7rem;font-weight:700;color:#ff2d78;margin-bottom:3px;font-family:var(--font-display);">Алина</div>
                    <div style="background:rgba(255,45,120,0.12);border:1px solid rgba(255,45,120,0.2);border-radius:4px 16px 16px 16px;padding:10px 14px;max-width:85%;">
                      <p class="font-body text-sm leading-relaxed" style="color:#fff8f0;">Дракон проснулся и обнаружил, что кто-то выпил весь его чай.</p>
                    </div>
                  </div>

                  <div style="display:flex;flex-direction:column;align-items:flex-end;">
                    <div style="font-size:0.7rem;font-weight:700;color:#00c2ff;margin-bottom:3px;font-family:var(--font-display);">Максим</div>
                    <div style="background:rgba(0,194,255,0.12);border:1px solid rgba(0,194,255,0.2);border-radius:16px 4px 16px 16px;padding:10px 14px;max-width:85%;">
                      <p class="font-body text-sm leading-relaxed" style="color:#fff8f0;">Виновником оказался гном в деловом галстуке и полосатых носках.</p>
                    </div>
                  </div>

                  <div>
                    <div style="font-size:0.7rem;font-weight:700;color:#39ff6e;margin-bottom:3px;font-family:var(--font-display);">Катя</div>
                    <div style="background:rgba(57,255,110,0.12);border:1px solid rgba(57,255,110,0.2);border-radius:4px 16px 16px 16px;padding:10px 14px;max-width:85%;">
                      <p class="font-body text-sm leading-relaxed" style="color:#fff8f0;">Дракон предложил сыграть в шахматы на желание.</p>
                    </div>
                  </div>

                  <!-- typing indicator -->
                  <div style="display:flex;flex-direction:column;align-items:flex-end;opacity:0.6;">
                    <div style="background:rgba(245,166,35,0.1);border:1px solid rgba(245,166,35,0.15);border-radius:16px 4px 16px 16px;padding:12px 16px;display:flex;gap:4px;align-items:center;">
                      <span style="width:6px;height:6px;border-radius:50%;background:#ffc94a;" class="animate-pulse"></span>
                      <span style="width:6px;height:6px;border-radius:50%;background:#ffc94a;animation-delay:0.2s;" class="animate-pulse"></span>
                      <span style="width:6px;height:6px;border-radius:50%;background:#ffc94a;animation-delay:0.4s;" class="animate-pulse"></span>
                    </div>
                  </div>

                </div>

                <!-- footer bar -->
                <div style="padding:8px 18px;border-top:1px solid rgba(245,166,35,0.1);background:rgba(0,0,0,0.2);display:flex;justify-content:space-between;align-items:center;">
                  <span class="font-mono text-xs" style="color:#b07040;">Раунд 3 из 4</span>
                  <span class="font-mono text-xs" style="color:#b07040;">3 игрока</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
        <span class="font-body text-xs" style="color:#b07040;">листайте вниз</span>
        <div style="width:1px;height:32px;background:linear-gradient(to bottom,rgba(245,166,35,0.5),transparent);"></div>
      </div>
    </section>

    <section id="how" class="relative py-28 px-6 overflow-hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(245,166,35,0.1) 0%,transparent 65%);pointer-events:none;"></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="text-center mb-16">
          <div class="divider-game mb-5 font-mono text-xs tracking-[0.3em] uppercase" style="color:rgba(245,166,35,0.5);">
            Механика игры
          </div>
          <h2 class="font-display font-black tracking-tight mb-4" style="color:#fff8f0;font-size:clamp(2.2rem,5vw,3.5rem);">
            Три шага до смеха
          </h2>
          <p class="font-body" style="color:#ffcfa0;">Простые правила — бесконечные вариации сюжета</p>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
          {steps.map(({ step, Icon, title, desc }) => (
            <div class="card-game rounded-[--radius-xl] p-8 overflow-hidden relative group">
              <div class="step-number absolute top-4 right-5 select-none leading-none">{step}</div>
              <div style="display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,rgba(245,166,35,0.15),rgba(245,166,35,0.05));border:1px solid rgba(245,166,35,0.2);margin-bottom:1.25rem;">
                <Icon size={24} color="#ffc94a" stroke-width={1.5} />
              </div>
              <h3 class="font-display font-bold text-lg mb-3 group-hover:text-orange-glow transition-colors duration-300" style="color:#fff8f0;">{title}</h3>
              <p class="font-body text-sm leading-relaxed" style="color:#ffcfa0;">{desc}</p>
              <div style="position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(245,166,35,0),transparent);transition:all 0.4s;" class="group-hover:[background:linear-gradient(to_right,transparent,rgba(245,166,35,0.45),transparent)]"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="features" class="relative py-28 px-6 overflow-hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 50% 100%,rgba(245,166,35,0.08) 0%,transparent 65%),linear-gradient(to bottom,transparent,rgba(34,20,0,0.6),transparent);pointer-events:none;"></div>

      <div class="relative mx-auto max-w-6xl">
        <div class="text-center mb-16">
          <div class="divider-game mb-5 font-mono text-xs tracking-[0.3em] uppercase" style="color:rgba(245,166,35,0.5);">
            Возможности
          </div>
          <h2 class="font-display font-black tracking-tight mb-4" style="color:#fff8f0;font-size:clamp(2.2rem,5vw,3.5rem);">
            Всё для весёлой игры
          </h2>
          <p class="font-body" style="color:#ffcfa0;">Продуманные инструменты, которые не мешают, а помогают</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {features.map(({ Icon, title, desc }) => (
            <div class="card-game rounded-[--radius-lg] p-6 group cursor-default">
              <div style="display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(245,166,35,0.12),rgba(245,166,35,0.05));border:1px solid rgba(245,166,35,0.18);margin-bottom:1rem;">
                <Icon size={20} color="#ffc94a" stroke-width={1.5} />
              </div>
              <h3 class="font-display font-bold mb-2 group-hover:text-orange-glow transition-colors duration-200" style="color:#fff8f0;">{title}</h3>
              <p class="font-body text-sm leading-relaxed" style="color:#ffcfa0;">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-28 px-6">
      <div class="mx-auto max-w-4xl">
        <div class="relative rounded-3xl overflow-hidden text-center" style="background:linear-gradient(145deg,#1f1000 0%,#2e1800 50%,#1a0c00 100%);border:1px solid rgba(245,166,35,0.2);box-shadow:0 0 0 1px rgba(245,166,35,0.06),0 30px 80px rgba(0,0,0,0.6),inset 0 1px 0 rgba(255,201,74,0.08);">
          <div style="position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:500px;height:300px;border-radius:50%;background:radial-gradient(ellipse,rgba(245,166,35,0.2) 0%,transparent 65%);filter:blur(20px);pointer-events:none;"></div>
          <div style="height:2px;background:linear-gradient(to right,transparent,rgba(245,166,35,0.6),rgba(255,201,74,0.4),transparent);"></div>

          <div class="relative px-8 md:px-16 py-14">
            <div class="badge-game mx-auto mb-6 w-fit">
              <EyeOff size={14} stroke-width={1.5} /> Главная фишка
            </div>
            <h2 class="font-display font-black tracking-tight mb-5" style="color:#fff8f0;font-size:clamp(1.9rem,4vw,3rem);">
              Blind Mode —<br />
              <span class="text-orange-gradient">хаос по правилам</span>
            </h2>
            <p class="font-body text-lg leading-relaxed mb-10 mx-auto" style="color:#ffcfa0;max-width:44ch;">
              Когда каждый видит только одно предложение, история уходит туда, куда никто не ожидал.
              Именно в этом непредсказуемом хаосе и живёт веселье.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              {['Видно только последнее', 'Каждый раз по-новому', 'Смех гарантирован'].map((label) => (
                <div style="display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-radius:10px;background:rgba(245,166,35,0.08);border:1px solid rgba(245,166,35,0.2);font-size:0.875rem;font-weight:600;color:#ffcfa0;font-family:var(--font-body);">
                  <span style="color:#ffc94a;font-size:1rem;">✦</span> {label}
                </div>
              ))}
            </div>
          </div>

          <div style="height:2px;background:linear-gradient(to right,transparent,rgba(245,166,35,0.4),rgba(255,45,120,0.2),transparent);"></div>
        </div>
      </div>
    </section>

    <section id="play" class="relative py-36 px-6 text-center overflow-hidden">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 50% 100%,rgba(245,166,35,0.15) 0%,transparent 60%),radial-gradient(ellipse 50% 60% at 50% 80%,rgba(245,166,35,0.12) 0%,transparent 55%);pointer-events:none;"></div>

      <div class="relative mx-auto max-w-2xl">
        <div class="text-5xl mb-6 animate-wiggle" style="line-height:1;">🎲</div>
        <h2 class="font-display font-black tracking-tight mb-5" style="color:#fff8f0;font-size:clamp(2.5rem,6vw,4rem);">
          Готовы к игре?
        </h2>
        <p class="font-body text-lg leading-relaxed mb-12 mx-auto" style="color:#ffcfa0;max-width:36ch;">
          Соберите друзей, поделитесь кодом и начните писать историю — это займёт меньше минуты.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={appUrl} target="_blank" rel="noopener noreferrer" class="btn-primary rounded-[14px] px-10 py-4 text-lg font-display font-bold text-center">
            Создать комнату →
          </a>
          <a href={`${appUrl}?tab=join`} target="_blank" rel="noopener noreferrer" class="btn-outline rounded-[14px] px-10 py-4 text-lg text-center">
            Войти по коду
          </a>
        </div>
        <p class="mt-10 font-body text-sm" style="color:#b07040;">
          Без регистрации · Бесплатно · Прямо в браузере
        </p>
      </div>
    </section>

    <Footer />
  </body>
</html>
