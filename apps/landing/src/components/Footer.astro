---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer style="border-top:1px solid rgba(245,166,35,0.12);padding:2rem 1.5rem;">
  <div class="mx-auto max-w-6xl flex flex-col sm:flex-row items-center justify-between gap-4 font-body text-sm" style="color:#b07040;">
    <div class="flex items-center gap-2">
      <span class="font-display font-black" style="color:#ffcfa0;">StoryForge</span>
    </div>
    <span>© {year} StoryForge. Сделано с любовью к историям.</span>
    <div class="flex gap-6">
      <a href={`${base}/rules`}   class="hover:text-fg-muted transition-colors duration-150">Правила</a>
      <a href={`${base}/contact`} class="hover:text-fg-muted transition-colors duration-150">Контакты</a>
    </div>
  </div>
</footer>
