---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const appUrl = import.meta.env.PUBLIC_APP_URL ?? '#';
---
<header
  style="background:rgba(34,20,0,0.88);border-bottom:1px solid rgba(245,166,35,0.15);"
  class="fixed top-0 inset-x-0 z-50 backdrop-blur-xl"
>
  <div class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between">
    <a href={import.meta.env.BASE_URL} class="flex items-center gap-2.5 group">
      <span style="color:#f5a623;" class="text-xl leading-none animate-glow-pulse">🔥</span>
      <span class="font-display font-black text-lg tracking-tight" style="color:#fff8f0;">StoryForge</span>
    </a>
    <nav class="hidden md:flex items-center gap-8 font-body text-sm font-semibold" style="color:#ffcfa0;">
      <a href={`${base}/#how`}      class="hover:text-[#fff8f0] transition-colors duration-200">Как играть</a>
      <a href={`${base}/#features`} class="hover:text-[#fff8f0] transition-colors duration-200">Возможности</a>
      <a href={`${base}/#play`}     class="hover:text-[#fff8f0] transition-colors duration-200">Играть</a>
    </nav>
    <a href={appUrl} target="_blank" rel="noopener noreferrer" class="btn-primary rounded-[14px] px-5 py-2.5 text-sm font-display font-bold">
      Начать игру
    </a>
  </div>
</header>
